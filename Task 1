<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lumina — Online Learning Platform · Prototype</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0d0d0d;
    --cream: #f9f5ef;
    --warm: #f2ede3;
    --gold: #c9a84c;
    --gold-light: #f0e0b0;
    --gold-dark: #8a6820;
    --sage: #4a6741;
    --sage-light: #e8f0e7;
    --rust: #b84a2e;
    --rust-light: #fbeae6;
    --muted: #6b6560;
    --border: #e0d8cc;
    --card: #ffffff;
    --shadow: 0 2px 16px rgba(13,13,13,0.08);
    --shadow-lg: 0 8px 40px rgba(13,13,13,0.13);
    --radius: 14px;
    --radius-sm: 8px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #e8e2d9;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    padding: 24px 16px 48px;
    color: var(--ink);
  }

  /* ── PROTOTYPE CHROME ── */
  .proto-header {
    width: 100%;
    max-width: 960px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .proto-title { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--ink); }
  .proto-title span { color: var(--gold-dark); }
  .proto-nav { display: flex; gap: 6px; flex-wrap: wrap; }
  .proto-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1.5px solid var(--border);
    background: var(--cream);
    color: var(--muted);
    cursor: pointer;
    transition: all 0.18s;
  }
  .proto-btn:hover { border-color: var(--gold); color: var(--gold-dark); }
  .proto-btn.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }

  /* ── DEVICE FRAME ── */
  .device-frame {
    width: 100%;
    max-width: 960px;
    background: var(--card);
    border-radius: 20px;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(0,0,0,0.06);
    overflow: hidden;
    position: relative;
    min-height: 680px;
  }

  /* ── BROWSER BAR ── */
  .browser-bar {
    height: 44px;
    background: #f5f5f5;
    border-bottom: 1px solid #e8e8e8;
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 8px;
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; }
  .dot.r { background: #ff5f57; }
  .dot.y { background: #febc2e; }
  .dot.g { background: #28c840; }
  .url-bar {
    flex: 1; height: 26px; background: #e8e8e8;
    border-radius: 6px; display: flex; align-items: center;
    padding: 0 10px; font-size: 12px; color: #888; margin: 0 12px;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── SCREENS ── */
  .screen { display: none; animation: fadeIn 0.25s ease; }
  .screen.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* ═══════════════════════════
     SCREEN 1 — HOME / LANDING
  ═══════════════════════════ */
  .home-nav {
    height: 64px;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
  }
  .logo { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--ink); letter-spacing: -0.5px; }
  .logo em { font-style: normal; color: var(--gold-dark); }
  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links a {
    font-size: 14px; font-weight: 500; color: var(--muted);
    text-decoration: none; cursor: pointer; transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--ink); }
  .nav-cta {
    background: var(--ink); color: var(--cream);
    padding: 9px 22px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    cursor: pointer; border: none;
    transition: background 0.15s;
    font-family: 'DM Sans', sans-serif;
  }
  .nav-cta:hover { background: var(--gold-dark); }

  .hero {
    background: var(--cream);
    padding: 72px 48px 56px;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 48px;
    align-items: center;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--gold-light); color: var(--gold-dark);
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 5px 12px; border-radius: 20px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 52px; line-height: 1.1; font-weight: 700;
    color: var(--ink); margin-bottom: 18px;
  }
  .hero h1 em { font-style: italic; color: var(--gold-dark); }
  .hero-sub {
    font-size: 17px; color: var(--muted); line-height: 1.6;
    margin-bottom: 32px; font-weight: 300;
  }
  .hero-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
  .btn-primary {
    background: var(--ink); color: var(--cream);
    padding: 13px 28px; border-radius: 10px;
    font-size: 15px; font-weight: 600;
    cursor: pointer; border: none;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.18s;
  }
  .btn-primary:hover { background: var(--gold-dark); transform: translateY(-1px); }
  .btn-ghost {
    background: transparent; color: var(--muted);
    padding: 13px 28px; border-radius: 10px;
    font-size: 15px; font-weight: 500;
    cursor: pointer; border: 2px solid var(--border);
    font-family: 'DM Sans', sans-serif;
    transition: all 0.18s;
  }
  .btn-ghost:hover { border-color: var(--ink); color: var(--ink); }
  .hero-stats { display: flex; gap: 28px; margin-top: 28px; }
  .stat { }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--ink); }
  .stat-label { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .hero-visual {
    background: var(--warm);
    border-radius: 20px;
    border: 1px solid var(--border);
    overflow: hidden;
    height: 360px;
    position: relative;
  }
  .hero-card {
    position: absolute; background: white;
    border-radius: 12px; padding: 16px 18px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .hc1 { top: 24px; left: 24px; right: 24px; }
  .hc2 { bottom: 80px; left: 24px; width: 180px; }
  .hc3 { bottom: 24px; right: 24px; width: 160px; }
  .hc-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); margin-bottom: 6px; }
  .hc-title { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
  .hc-sub { font-size: 12px; color: var(--muted); }
  .progress-bar { height: 4px; background: var(--border); border-radius: 4px; margin-top: 10px; }
  .progress-fill { height: 100%; border-radius: 4px; background: var(--gold); }
  .avatar-row { display: flex; gap: -6px; margin-top: 8px; }
  .av {
    width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid white; background: var(--sage-light);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 600; color: var(--sage);
    margin-left: -6px;
  }
  .av:first-child { margin-left: 0; }
  .badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--sage); display: inline-block; margin-right: 5px; }

  .section {
    padding: 56px 48px;
    background: var(--card);
    border-top: 1px solid var(--border);
  }
  .section-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--gold-dark);
    margin-bottom: 10px;
  }
  .section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 34px; font-weight: 700; color: var(--ink);
    margin-bottom: 8px;
  }
  .section-sub { font-size: 15px; color: var(--muted); margin-bottom: 36px; }

  .course-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .course-card {
    border: 1px solid var(--border); border-radius: var(--radius);
    overflow: hidden; background: var(--card);
    transition: box-shadow 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .course-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .course-thumb {
    height: 130px; display: flex; align-items: center; justify-content: center;
    font-size: 48px; position: relative;
  }
  .course-body { padding: 16px 18px; }
  .course-cat {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; margin-bottom: 6px;
  }
  .course-title { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 6px; line-height: 1.3; }
  .course-meta { display: flex; align-items: center; justify-content: space-between; }
  .course-inst { font-size: 12px; color: var(--muted); }
  .course-price { font-size: 15px; font-weight: 700; color: var(--ink); }
  .stars { color: var(--gold); font-size: 11px; margin-bottom: 4px; }

  .features-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .feature-card {
    padding: 24px 20px;
    background: var(--warm);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .feature-icon { font-size: 28px; margin-bottom: 12px; }
  .feature-title { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
  .feature-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }

  /* ═══════════════════════════
     SCREEN 2 — COURSE CATALOG
  ═══════════════════════════ */
  .catalog-layout { display: grid; grid-template-columns: 240px 1fr; min-height: calc(100% - 108px); }
  .sidebar {
    background: var(--warm);
    border-right: 1px solid var(--border);
    padding: 28px 20px;
  }
  .sidebar-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 12px; }
  .filter-group { margin-bottom: 24px; }
  .filter-option {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--ink); padding: 5px 0;
    cursor: pointer;
  }
  .filter-option input[type=checkbox] { accent-color: var(--gold-dark); width: 14px; height: 14px; }
  .filter-count { font-size: 11px; color: var(--muted); margin-left: auto; }
  .price-range { height: 3px; background: var(--border); border-radius: 3px; margin: 10px 0; position: relative; }
  .price-fill { position: absolute; left: 0; width: 65%; height: 100%; background: var(--gold); border-radius: 3px; }

  .catalog-main { padding: 28px 32px; background: var(--cream); }
  .catalog-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .catalog-top h2 { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--ink); }
  .sort-select {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; padding: 7px 12px;
    border: 1px solid var(--border); border-radius: 8px;
    background: var(--card); color: var(--ink); cursor: pointer;
  }
  .search-field {
    display: flex; align-items: center; gap: 10px;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 10px; padding: 9px 14px; margin-bottom: 20px;
  }
  .search-field input {
    border: none; outline: none; background: transparent;
    font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--ink); flex: 1;
  }
  .search-field input::placeholder { color: var(--muted); }
  .catalog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }

  /* ═══════════════════════════
     SCREEN 3 — COURSE DETAIL
  ═══════════════════════════ */
  .detail-hero {
    background: var(--ink);
    padding: 40px 48px;
    color: var(--cream);
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 40px;
  }
  .detail-breadcrumb { font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 14px; }
  .detail-breadcrumb span { color: var(--gold); cursor: pointer; }
  .detail-tag {
    display: inline-block; background: var(--gold);
    color: var(--ink); font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding: 4px 10px; border-radius: 20px; margin-bottom: 14px;
  }
  .detail-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 32px; font-weight: 700; line-height: 1.2;
    margin-bottom: 12px;
  }
  .detail-hero p { font-size: 15px; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 18px; }
  .detail-meta { display: flex; gap: 20px; font-size: 13px; color: rgba(255,255,255,0.6); flex-wrap: wrap; }
  .detail-meta strong { color: white; }

  .enroll-card {
    background: var(--card);
    border-radius: 16px;
    padding: 24px;
    color: var(--ink);
    height: fit-content;
  }
  .enroll-price { font-family: 'Playfair Display', serif; font-size: 34px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
  .enroll-orig { font-size: 14px; color: var(--muted); text-decoration: line-through; margin-bottom: 16px; }
  .enroll-includes { font-size: 12px; color: var(--muted); margin-top: 16px; }
  .include-item { display: flex; gap: 8px; font-size: 13px; padding: 5px 0; color: var(--ink); align-items: center; }
  .include-icon { color: var(--sage); font-weight: 700; }

  .detail-body { padding: 40px 48px; display: grid; grid-template-columns: 1fr 300px; gap: 40px; background: var(--cream); }
  .detail-body-main {}
  .detail-section-title { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: var(--ink); margin-bottom: 16px; }
  .learn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 28px; }
  .learn-item { display: flex; gap: 8px; font-size: 13px; color: var(--ink); align-items: flex-start; }
  .learn-check { color: var(--sage); font-weight: 700; flex-shrink: 0; }

  .curriculum { }
  .module {
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    margin-bottom: 8px; overflow: hidden;
  }
  .module-header {
    padding: 12px 16px; background: var(--warm);
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; font-size: 14px; font-weight: 600; color: var(--ink);
  }
  .module-meta { font-size: 12px; color: var(--muted); font-weight: 400; }
  .module-lessons { padding: 8px 16px; background: var(--card); }
  .lesson { display: flex; align-items: center; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--muted); }
  .lesson:last-child { border-bottom: none; }
  .lesson-icon { font-size: 14px; }
  .lesson-dur { margin-left: auto; font-size: 12px; }

  .instructor-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px;
  }
  .inst-top { display: flex; gap: 12px; align-items: center; margin-bottom: 12px; }
  .inst-avatar {
    width: 52px; height: 52px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold-light), var(--sage-light));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; color: var(--gold-dark);
    flex-shrink: 0;
  }
  .inst-name { font-size: 15px; font-weight: 600; color: var(--ink); }
  .inst-title { font-size: 12px; color: var(--muted); }
  .inst-bio { font-size: 13px; color: var(--muted); line-height: 1.5; }

  /* ═══════════════════════════
     SCREEN 4 — DASHBOARD
  ═══════════════════════════ */
  .dash-layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100% - 64px); }
  .dash-sidebar {
    background: var(--ink);
    padding: 28px 0;
  }
  .dash-logo { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--cream); padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }
  .dash-logo em { font-style: normal; color: var(--gold); }
  .dash-nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px; font-size: 13px; font-weight: 500;
    color: rgba(255,255,255,0.5); cursor: pointer; transition: all 0.15s;
  }
  .dash-nav-item:hover { color: var(--cream); background: rgba(255,255,255,0.05); }
  .dash-nav-item.active { color: var(--cream); background: rgba(201,168,76,0.15); border-right: 3px solid var(--gold); }
  .dash-nav-icon { font-size: 16px; }

  .dash-main { background: var(--cream); padding: 32px 36px; overflow-y: auto; }
  .dash-greeting { margin-bottom: 28px; }
  .dash-greeting h2 { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: var(--ink); }
  .dash-greeting p { font-size: 14px; color: var(--muted); margin-top: 4px; }

  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
  .stat-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 18px;
  }
  .stat-card-num { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: var(--ink); }
  .stat-card-label { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .stat-card-icon { font-size: 22px; margin-bottom: 8px; }

  .dash-grid { display: grid; grid-template-columns: 1fr 280px; gap: 20px; }
  .enrolled-section-title { font-size: 16px; font-weight: 600; color: var(--ink); margin-bottom: 14px; }

  .enrolled-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 16px 18px;
    display: flex; gap: 14px; align-items: center;
    margin-bottom: 12px; cursor: pointer; transition: box-shadow 0.2s;
  }
  .enrolled-card:hover { box-shadow: var(--shadow); }
  .enrolled-thumb {
    width: 56px; height: 56px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; flex-shrink: 0;
  }
  .enrolled-info { flex: 1; }
  .enrolled-title { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .enrolled-inst { font-size: 12px; color: var(--muted); margin-bottom: 8px; }
  .enrolled-progress { height: 4px; background: var(--border); border-radius: 4px; }
  .enrolled-pfill { height: 100%; border-radius: 4px; background: var(--gold); }
  .enrolled-pct { font-size: 11px; color: var(--muted); margin-top: 3px; }
  .continue-btn {
    background: var(--ink); color: var(--cream);
    border: none; border-radius: 8px;
    padding: 8px 14px; font-size: 12px; font-weight: 600;
    cursor: pointer; white-space: nowrap;
    font-family: 'DM Sans', sans-serif;
    transition: background 0.15s;
  }
  .continue-btn:hover { background: var(--gold-dark); }

  .activity-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 18px;
    height: fit-content;
  }
  .activity-item { display: flex; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .activity-item:last-child { border-bottom: none; }
  .act-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 4px; }
  .act-text { color: var(--ink); line-height: 1.4; }
  .act-time { font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* ═════════════════════════
     SCREEN 5 — LESSON PLAYER
  ═════════════════════════ */
  .player-layout { display: grid; grid-template-columns: 1fr 320px; min-height: calc(100% - 64px); }
  .player-main { background: #0d0d0d; display: flex; flex-direction: column; }
  .video-area {
    background: #111; flex: 1; display: flex; align-items: center; justify-content: center;
    position: relative; min-height: 340px;
  }
  .play-btn {
    width: 64px; height: 64px; border-radius: 50%;
    background: rgba(201,168,76,0.9); display: flex; align-items: center;
    justify-content: center; cursor: pointer; transition: all 0.15s;
  }
  .play-btn:hover { background: var(--gold); transform: scale(1.06); }
  .play-icon { font-size: 22px; color: var(--ink); margin-left: 4px; }
  .video-label {
    position: absolute; top: 16px; left: 16px;
    background: rgba(0,0,0,0.6); color: rgba(255,255,255,0.8);
    font-size: 12px; padding: 4px 10px; border-radius: 6px;
  }
  .video-controls {
    background: #1a1a1a; padding: 12px 20px;
    display: flex; align-items: center; gap: 14px;
  }
  .vc-btn { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 18px; cursor: pointer; padding: 4px; }
  .vc-btn:hover { color: white; }
  .seek-bar { flex: 1; height: 4px; background: #444; border-radius: 4px; position: relative; cursor: pointer; }
  .seek-fill { height: 100%; width: 42%; background: var(--gold); border-radius: 4px; }
  .seek-thumb { position: absolute; right: 58%; top: 50%; transform: translate(50%, -50%); width: 12px; height: 12px; border-radius: 50%; background: var(--gold); }
  .vc-time { font-size: 12px; color: rgba(255,255,255,0.5); white-space: nowrap; }

